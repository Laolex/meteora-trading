# Solana RPC
HELIUS_API_KEY=
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
SOLANA_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}

# Wallet (filesystem path to JSON keypair — never commit the file)
HOT_WALLET_KEYPAIR_PATH=/home/claude/.config/solana/meteora-hot.json

# Database
DATABASE_URL=postgresql://meteora:meteora@localhost:5432/meteora_agent

# Execution
NODE_HELPER_PATH=node-helper/index.js
DEFAULT_POSITION_SIZE_USD=100
TARGET_POSITION_WIDTH_BINS=40
MAX_OPEN_POSITIONS=1

# Meteora API
METEORA_API_BASE=https://dlmm.datapi.meteora.ag

# Agent mode
DRY_RUN=true                          # MUST be set to false explicitly to send mainnet txs
NETWORK=devnet                         # devnet | mainnet
LOOP_INTERVAL_SECONDS=60

# Safety rails (USD)
MAX_POSITION_USD=100
MAX_TOTAL_DEPLOYED_USD=500
DAILY_LOSS_LIMIT_PCT=10
KILL_SWITCH_FILE=/tmp/meteora-killswitch

# Discovery scoring weights (must sum to 1.0)
SCORE_WEIGHT_FEES_24H=0.4
SCORE_WEIGHT_VOLUME_TVL=0.3
SCORE_WEIGHT_TOKEN_QUALITY=0.2
SCORE_WEIGHT_BIN_LIQUIDITY=0.1

# Rebalance thresholds
REBALANCE_DRIFT_BPS=50                # rebalance if active bin > 50bps from position center
REBALANCE_MIN_FEES_USD=0.10           # don't rebalance if accumulated fees < this (gas inefficient)
EXIT_VOLATILITY_24H_PCT=30            # exit position if 24h price move > 30%

# Dashboard
DASHBOARD_PORT=8000
DASHBOARD_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/meteora-agent.log
